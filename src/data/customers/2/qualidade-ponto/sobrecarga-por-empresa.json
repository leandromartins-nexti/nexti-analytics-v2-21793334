{
  "-- =====================================================\n-- Sobrecarga do Back-office - 3 QUERIES OTIMIZADAS (V5 final)\n-- Customer dinâmico no SELECT (sem hardcode no resultado)\n-- =====================================================\n-- POR EMPRESA\n-- =====================================================\nWITH he_types AS (\n  SELECT id \n  FROM time_tracking_type\n  WHERE (name LIKE '%OVERTIME%' OR name LIKE 'COMPTIME_CREDIT%')\n    AND name NOT LIKE '%BALANCE%'\n),\nhe_operador_mes AS (\n  SELECT \n    tt.person_id AS operador_person_id,\n    DATE_FORMAT(tt.reference_date, '%Y-%m') AS competencia,\n    SUM(tt.minutes) / 60.0 AS horas_extras\n  FROM time_tracking tt\n  INNER JOIN he_types ht ON ht.id = tt.time_tracking_type_id\n  WHERE tt.customer_id = 2\n    AND tt.reference_date >= '2025-04-01'\n    AND tt.reference_date < '2026-04-01'\n  GROUP BY tt.person_id, DATE_FORMAT(tt.reference_date, '%Y-%m')\n),\najustes_por_person_op AS (\n  SELECT \n    ajuste.customer_id,\n    ajuste.person_id AS colaborador_person_id,\n    DATE_FORMAT(ajuste.reference_date, '%Y-%m') AS competencia,\n    ua.person_id AS operador_person_id,\n    ua.id AS user_account_id,\n    COUNT(*) AS qtd\n  FROM clocking ajuste\n  INNER JOIN user_account ua ON ua.id = ajuste.user_adjustment_id\n  WHERE ajuste.customer_id = 2\n    AND ajuste.removed = 0\n    AND ajuste.clocking_type_id = 3\n    AND ajuste.clocking_origin_id IS NOT NULL\n    AND ajuste.adjustment_date IS NOT NULL\n    AND ajuste.reference_date >= '2025-04-01'\n    AND ajuste.reference_date < '2026-04-01'\n  GROUP BY ajuste.customer_id, ajuste.person_id, DATE_FORMAT(ajuste.reference_date, '%Y-%m'), ua.person_id, ua.id\n),\najustes_por_empresa_op AS (\n  SELECT \n    apo.customer_id,\n    p.company_id,\n    apo.competencia,\n    apo.operador_person_id,\n    apo.user_account_id,\n    SUM(apo.qtd) AS qtd\n  FROM ajustes_por_person_op apo\n  INNER JOIN person p ON p.id = apo.colaborador_person_id\n  GROUP BY apo.customer_id, p.company_id, apo.competencia, apo.operador_person_id, apo.user_account_id\n),\najustes_operador_total_mes AS (\n  SELECT \n    operador_person_id,\n    competencia,\n    SUM(qtd) AS total_ajustes_op\n  FROM ajustes_por_empresa_op\n  GROUP BY operador_person_id, competencia\n)\nSELECT \n  ag.customer_id,\n  ag.competencia,\n  ag.company_id,\n  comp.company_name,\n  SUM(ag.qtd) AS qtd_ajustes,\n  COUNT(DISTINCT ag.user_account_id) AS operadores_ativos,\n  ROUND(\n    SUM(ag.qtd) * 1.0 / NULLIF(COUNT(DISTINCT ag.user_account_id), 0),\n    0\n  ) AS ajustes_por_operador,\n  ROUND(\n    SUM(\n      COALESCE(hom.horas_extras, 0)\n      * ag.qtd\n      / NULLIF(aotm.total_ajustes_op, 0)\n    ),\n    1\n  ) AS horas_extras_rateadas\nFROM ajustes_por_empresa_op ag\nLEFT JOIN company comp ON comp.id = ag.company_id\nLEFT JOIN he_operador_mes hom\n  ON hom.operador_person_id = ag.operador_person_id\n  AND hom.competencia = ag.competencia\nLEFT JOIN ajustes_operador_total_mes aotm\n  ON aotm.operador_person_id = ag.operador_person_id\n  AND aotm.competencia = ag.competencia\nGROUP BY ag.customer_id, ag.competencia, ag.company_id, comp.company_name\nORDER BY ag.company_id, ag.competencia": [
