# ── Data source ─────────────────────────────────────────
# When true (default), the app reads bundled JSONs. When false, it
# fetches the nexti-analytics-api at VITE_API_URL.
VITE_USE_MOCK_DATA=true

# Base URL of the backend API. Only used when VITE_USE_MOCK_DATA=false.
# Must match the CORS_ORIGIN allowed by the API.
VITE_API_URL=http://localhost:3001
